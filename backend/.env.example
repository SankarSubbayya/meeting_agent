# Copy to .env and fill in values. See docs/API_KEYS.md

INTERNAL_API_KEY=change-me
DATABASE_URL=sqlite+aiosqlite:///./meeting_agents.db
REDIS_URL=redis://localhost:6379/0

FIREFLIES_API_KEY=
FIREFLIES_GRAPHQL_URL=https://api.fireflies.ai/graphql
FIREFLIES_TIMEOUT_SECONDS=60

GUILD_API_BASE=
GUILD_API_KEY=
GUILD_WORKFLOW_MEETING_PATH=/v1/workflows/meeting-to-actions/run

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0

TINYFISH_API_KEY=
TINYFISH_BASE_URL=https://api.tinyfish.ai
TINYFISH_RUN_ASYNC_PATH=/v1/run-async

REDIS_CACHE_TTL_FIREFLIES_SECONDS=900
REDIS_RATE_LIMIT_PER_MINUTE=60

DEBUG=false
